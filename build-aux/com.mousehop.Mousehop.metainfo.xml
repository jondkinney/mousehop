<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>com.mousehop.Mousehop</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>Mousehop</name>
  <summary>Share one mouse, keyboard, and clipboard across machines</summary>
  <icon type="stock">com.mousehop.Mousehop</icon>
  <launchable type="desktop-id">com.mousehop.Mousehop.desktop</launchable>
  <description>
    <p>
      Mousehop is an open-source software KVM. Glide a single mouse, keyboard, and
      clipboard across Linux, macOS, and Windows machines over the local network — no
      KVM hardware, no cloud service.
    </p>
    <p>
      Mousehop is a fork of lan-mouse by Florian Eschberger, used under the GPL-3.0
      license, with a native menu-bar app, a system tray, per-peer tuning, sturdier
      discovery, and a refreshed UI.
    </p>
  </description>
  <screenshots>
    <screenshot type="default">
      <caption>The Mousehop main window — peers, clipboard privacy, network discovery, and auto-release tuning</caption>
      <image>https://mousehop.com/assets/screenshot-prefs.png</image>
    </screenshot>
  </screenshots>
  <categories>
    <category>Utility</category>
    <category>Network</category>
  </categories>
  <!-- OARS: every age-rating attribute defaults to "none", which is
       correct for a software KVM. Peer-to-peer over the user's own
       LAN with their own machines doesn't trigger social-info (which
       is scoped to third-party sharing). Self-closing element is the
       standard Flathub shorthand for an all-clean rating. -->
  <content_rating type="oars-1.1"/>
  <!-- Per-release entries: prepend a new <release> at the top when
       release-plz cuts a new tag. Required by Flathub for the
       Version history section on the listing page; the latest
       release is the only one strictly required. -->
  <releases>
    <release version="0.11.3" date="2026-05-19"/>
  </releases>
  <url type="homepage">https://mousehop.com</url>
  <url type="bugtracker">https://github.com/jondkinney/mousehop/issues</url>
  <developer_name>Jon Kinney</developer_name>
</component>
